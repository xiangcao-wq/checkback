AI_VISION_PROVIDER=qwen
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen3.7-plus-2026-05-26

# Fast verification is fail-closed. Keep off until shadow evaluation passes.
CHECKBACK_FAST_VERIFIER_MODE=off
QWEN_FAST_VERIFICATION_MODEL=qwen3.6-flash-2026-04-16
QWEN_FAST_VERIFICATION_TIMEOUT_MS=20000
QWEN_VERIFICATION_FALLBACK_MODEL=qwen3.7-plus-2026-05-26
QWEN_VERIFICATION_FALLBACK_TIMEOUT_MS=90000

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.6-sol

# Public self-hosting safeguards. Leave CHECKBACK_PUBLIC_ORIGIN empty for local development.
CHECKBACK_PUBLIC_ORIGIN=
CHECKBACK_ANALYSIS_ENABLED=true
CHECKBACK_RATE_WINDOW_MS=3600000
CHECKBACK_RATE_LIMIT=12
CHECKBACK_DAILY_LIMIT=120
CHECKBACK_MAX_CONCURRENT=3